# All settings are optional — every script has a sane default.

# Where index_notes.py writes and brain_ask.py reads the embedding index.
BRAIN_INDEX_DIR=index

# SQLite ledger: per-turn TurnState rows + retrieval A/B telemetry.
TURNSTATE_DB=turnstate.db

# Mirror every brain_ask.py answer into this file (handy for agents that read files).
BRAIN_ANSWER_OUT=_brain_answer.txt

# If set, --ab also writes a structured JSON diff here (for dashboards).
#BRAIN_AB_JSON=ab_last.json

# Label written into ab_recall.source ('work' = live usage; use e.g. 'eval' for batches).
#AB_SOURCE=work
